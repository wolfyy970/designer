{
  "buildCommand": "pnpm build && pnpm vercel:function:build",
  "outputDirectory": "dist",
  "env": {
    "NODEJS_HELPERS": "0"
  },
  "functions": {
    "api/[[...route]].js": {
      "includeFiles": "{config,prompts,skills}/**",
      "maxDuration": 800
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[[...route]].js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

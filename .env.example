# ─── Local dev ports (optional; defaults in server/dev-defaults.ts) ───
# Hono API bind + default preview URLs for Playwright when PREVIEW_PUBLIC_URL is unset.
# PORT=4731
# Vite dev server (strictPort). Must match CORS / localStorage origin you open in the browser.
# VITE_PORT=4732

# ─── Server-side only (used by Vite proxy, never sent to browser) ───
OPENROUTER_API_KEY=

# ─── Vitest: sandbox LLM tool tests (opt-in; never used by the Hono API) ───
# Run: SANDBOX_LLM_TEST=1 pnpm vitest run server/services/__tests__/sandbox-llm-tools.test.ts
# Use a separate OpenRouter key from OPENROUTER_API_KEY so tests never charge the prod/project key.
# SANDBOX_LLM_TEST=1
# OPENROUTER_API_KEY_TESTS=
# OpenRouter model id for those tests (optional; legacy alias: SANDBOX_LLM_MODEL)
# MODEL_SELECTOR=openai/gpt-4o-mini

# When unset or empty, all LLM routes clamp to OpenRouter + minimax/minimax-m2.5 and the UI cannot
# change provider/model. Set to false, 0, no, or off (case-insensitive) to allow normal selection.
# LOCKDOWN=false

# LM Studio URL (proxied by Vite dev server)
# VITE_LMSTUDIO_URL=http://localhost:1234

# ─── Default Providers ─────────────────────────────────────────────
# Models are fetched dynamically from each provider's API
VITE_DEFAULT_COMPILER_PROVIDER=openrouter   # openrouter | lmstudio
VITE_DEFAULT_GENERATION_PROVIDER=openrouter   # openrouter | lmstudio
# OpenRouter model for new Model nodes when unset (default: minimax/minimax-m2.5)
# VITE_DEFAULT_MODEL_ID=minimax/minimax-m2.5

# ─── Vision ───────────────────────────────────────────────────────────
# Comma-separated model ID substrings for LM Studio vision models
# Example: llava,minicpm-v,qwen2-vl
VITE_LMSTUDIO_VISION_MODELS=

# ─── Optional: local agent debug ingest (off by default) ─────────────
# Server-side POSTs to a Cursor/local ingest URL when set to 1
# DEBUG_AGENT_INGEST=1
# Browser (Vite dev only): also set on client
# VITE_DEBUG_AGENT_INGEST=1

# ─── Agentic evaluation (server) ─────────────────────────────────────
# Max PI revision rounds after the first eval (0–20). Default: 5
# AGENTIC_MAX_REVISION_ROUNDS=5
# Optional early stop: overall score ≥ this and zero hard fails (even if gate still wants revision)
# AGENTIC_MIN_OVERALL_SCORE=
# Disable Playwright headless browser eval (preflight-only). Tests disable automatically.
# BROWSER_PLAYWRIGHT_EVAL=0

# ─── Production / multi-user hardening (optional) ─────────────────────
# Comma-separated browser origins for CORS (custom domain or Vercel preview URL when not same-origin as API).
# When unset, only localhost dev origins are allowed.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
#
# Ephemeral preview sessions: max rows in the in-memory map (evicts oldest). Default 200.
# MAX_PREVIEW_SESSIONS=200
#
# Max approx UTF-8 bytes for POST /api/preview/sessions `files` map. Default 5MB.
# MAX_PREVIEW_PAYLOAD_BYTES=5242880
#
# Max concurrent agentic orchestration runs per serverless instance / process. Default 5 (503 when full).
# MAX_CONCURRENT_AGENTIC_RUNS=5
#
# NDJSON observability file sink: max chars per prompt/response field. In production, defaults to 2000 when unset.
# LLM_LOG_MAX_BODY_CHARS=2000

# ─── Server-side only (used by Vite proxy, never sent to browser) ───
OPENROUTER_API_KEY=

# When unset or empty, all LLM routes clamp to OpenRouter + minimax/minimax-m2.5 and the UI cannot
# change provider/model. Set to false, 0, no, or off (case-insensitive) to allow normal selection.
# LOCKDOWN=false

# LM Studio URL (proxied by Vite dev server)
# VITE_LMSTUDIO_URL=http://localhost:1234

# ─── Default Providers ─────────────────────────────────────────────
# Models are fetched dynamically from each provider's API
VITE_DEFAULT_COMPILER_PROVIDER=openrouter   # openrouter | lmstudio
VITE_DEFAULT_GENERATION_PROVIDER=openrouter   # openrouter | lmstudio
# OpenRouter model for new Model nodes when unset (default: minimax/minimax-m2.5)
# VITE_DEFAULT_MODEL_ID=minimax/minimax-m2.5

# ─── Vision ───────────────────────────────────────────────────────────
# Comma-separated model ID substrings for LM Studio vision models
# Example: llava,minicpm-v,qwen2-vl
VITE_LMSTUDIO_VISION_MODELS=

# ─── Langfuse (Cloud recommended) ───
# Base URL must match your account region (no trailing slash):
#   US:  https://us.cloud.langfuse.com  (default below)
#   EU:  https://cloud.langfuse.com
# Project → Settings → API Keys: create Public + Secret keys.
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# When keys are set, tracing may send prompts/completions to Langfuse — use an org-approved project/region for sensitive text.
# Deployment label for runtime fetches & Prompt Studio saves (default: production)
# LANGFUSE_PROMPT_LABEL=production
# Overwrite Langfuse when labeled body differs from repo/SQLite (dangerous if you edit in Prompt Studio).
# Default: unset — `pnpm db:seed` only creates missing prompts / repairs missing labels.
# LANGFUSE_SEED_SYNC=1
# One-time: backup SQLite with legacy PromptVersion → seed uses latest bodies (highest version, then id)
# LANGFUSE_PROMPT_IMPORT_SQLITE=./backup-prompts.sqlite
# If unset, seed also tries DATABASE_URL when it is file:… (legacy SQLite with PromptVersion table).

# Same host as LANGFUSE_BASE_URL so Observability → “Open Langfuse UI” works in the browser
VITE_LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Optional: self-hosted Docker stack (mothballed for most devs) — see docker/langfuse/README.md
# LANGFUSE_BASE_URL=http://localhost:3100
# VITE_LANGFUSE_BASE_URL=http://localhost:3100

# ─── Prompts ───────────────────────────────────────────────────────────
#
# LLM templates live in Langfuse prompt management. Start Langfuse, set keys above,
# then run `pnpm db:seed` to bootstrap **missing** prompts only (Prompt Studio stays source of truth).
# Body source when creating: LANGFUSE_PROMPT_IMPORT_SQLITE / legacy dev.db PromptVersion, else shared-defaults.
# To force-reset all prompts from repo/SQLite: `pnpm langfuse:sync-prompts` (sets LANGFUSE_SEED_SYNC).
# Edit in the app: Settings → Prompt Studio. Spec and hypothesis text are merged as user input.
# Inspect coverage: GET /api/prompts/status

# ─── Optional: local agent debug ingest (off by default) ─────────────
# Server-side POSTs to a Cursor/local ingest URL when set to 1
# DEBUG_AGENT_INGEST=1
# Browser (Vite dev only): also set on client
# VITE_DEBUG_AGENT_INGEST=1

# ─── Agentic evaluation (server) ─────────────────────────────────────
# Max PI revision rounds after the first eval (0–20). Default: 5
# AGENTIC_MAX_REVISION_ROUNDS=5
# Optional early stop: overall score ≥ this and zero hard fails (even if gate still wants revision)
# AGENTIC_MIN_OVERALL_SCORE=
# Disable Playwright headless browser eval (preflight-only). Tests disable automatically.
# BROWSER_PLAYWRIGHT_EVAL=0

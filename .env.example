# ─── Local dev ports (optional; defaults in server/dev-defaults.ts) ───
# Hono API bind + default preview URLs for Playwright when PREVIEW_PUBLIC_URL is unset.
# PORT=4731
# Vite dev server (strictPort). Must match CORS / localStorage origin you open in the browser.
# VITE_PORT=4732

# ─── Server-side only (used by Vite proxy / Vercel API, never sent to browser) ───
# Required for hosted generation with OpenRouter models.
# Changing this changes which OpenRouter account/project pays for model calls.
OPENROUTER_API_KEY=

# ─── Sandbox LLM integration tests (Vitest; opt-in; never used by the Hono API) ───
# Used by server/services/__tests__/sandbox-llm-tools.test.ts only.
# NOT read by the meta-harness/ CLI — that uses OPENROUTER_API_KEY + meta-harness/config.json.
# Run: RUN_SANDBOX_LLM_TESTS=1 pnpm vitest run server/services/__tests__/sandbox-llm-tools.test.ts
# Use a separate OpenRouter key from OPENROUTER_API_KEY so tests never charge the prod/project key.
# RUN_SANDBOX_LLM_TESTS=1
# Legacy alias also supported: SANDBOX_LLM_TEST=1
# OPENROUTER_API_KEY_TESTS=
# OpenRouter model id for those tests (optional; legacy alias: SANDBOX_LLM_MODEL)
# MODEL_SELECTOR=openai/gpt-4o-mini

# Lockdown and auto-improve feature flags now live in config/feature-flags.json.

# LM Studio URL (proxied by Vite dev server)
# VITE_LMSTUDIO_URL=http://localhost:1234

# ─── Default Providers ─────────────────────────────────────────────
# Provider/model preselect for auto-created Model nodes now live in
# config/provider-defaults.json (compilerProvider, modelId).

# ─── Vision ───────────────────────────────────────────────────────────
# Comma-separated model ID substrings for LM Studio vision models
# Example: llava,minicpm-v,qwen2-vl
VITE_LMSTUDIO_VISION_MODELS=

# ─── LogRocket (client session replay) ────────────────────────────────
# Optional in development: enables the SDK locally (omit to stay off).
# Production builds default to qbwhsc/designer-6dify when unset.
# VITE_LOGROCKET_APP_ID=qbwhsc/designer-6dify

# ─── Optional: local agent debug ingest (off by default) ─────────────
# Server-side POSTs to a Cursor/local ingest URL when set to 1
# DEBUG_AGENT_INGEST=1
# Browser (Vite dev only): also set on client
# VITE_DEBUG_AGENT_INGEST=1

# ─── Agentic evaluation (server) ─────────────────────────────────────
# Max PI revision rounds after the first evaluation pass.
# Default: 5. Valid range: 0–20.
# Lower values make runs cheaper/faster but give the agent fewer chances to fix issues.
# Higher values can improve difficult designs, but runs may take much longer and cost more.
# AGENTIC_MAX_REVISION_ROUNDS=5
#
# Optional early stop threshold. When set, the agent can stop early if the overall score is
# at least this value and there are zero hard failures. Leave empty for the built-in gate.
# Suggested range: 0.70–0.95. Higher values demand stronger results before early stop.
# AGENTIC_MIN_OVERALL_SCORE=
#
# Browser-grounded evaluation. Default: enabled in normal runs, disabled in tests.
# Set to 0 if the deployment platform cannot run Playwright/browser checks.
# Turning this off keeps generation working but removes browser-scored QA feedback.
# BROWSER_PLAYWRIGHT_EVAL=0

# ─── Production / multi-user hardening (optional) ─────────────────────
# Vercel + Hono adapter compatibility.
# Required when deploying the Hono API through @hono/node-server/vercel.
# It disables Vercel's Node.js helper layer so Hono receives the raw request/response
# streams it needs for SSE. This is not a product setting and does not affect local dev.
# vercel.json sets this automatically for Vercel deployments; keep it here so manual
# platform configuration is understandable.
# NODEJS_HELPERS=0
#
# Browser origins allowed to call the API from another origin.
# Default: empty. In development, localhost origins are allowed automatically.
# For same-origin production (SPA and API on the same Vercel domain), this can stay empty.
# Set it when using a custom domain, a separate frontend host, or Vercel preview URLs.
# Format: comma-separated origins, no trailing path.
# Example:
# ALLOWED_ORIGINS=https://your-designer-app.vercel.app,https://your-custom-domain.com
#
# Temporary preview slots held in server memory.
# A preview slot is one generated design's file bundle so the iframe/evaluator can load
# its HTML/CSS/JS/assets. This is per serverless instance and not durable storage.
# Default: 200. Valid range: 1–50000.
# Lower values use less memory but old previews disappear sooner.
# Higher values keep more previews available but increase per-instance memory use.
# MAX_PREVIEW_SESSIONS=200
#
# Max total size of one preview upload, measured across the generated file bundle.
# In user terms: the largest generated design package the server will accept for preview.
# Default: 5MB (5242880 bytes). Valid range: 64KB–50MB.
# Lower values reject oversized/generated-heavy outputs earlier.
# Higher values allow larger designs but increase memory and request-size pressure.
# MAX_PREVIEW_PAYLOAD_BYTES=5242880
#
# Max active design-generation runs per serverless instance / process.
# Default: 5. Valid range: 1–100.
# Lower values protect the instance from overload but reject/queue fewer simultaneous users.
# Higher values allow more parallel runs but can exhaust CPU/memory or provider rate limits.
# When full, new runs receive an overload-style error instead of starting.
# MAX_CONCURRENT_AGENTIC_RUNS=5
#
# Public origin used when the server needs to open its own preview URLs, mainly for
# Playwright/browser evaluation. Use the production URL users actually load.
# No trailing slash. If this is wrong, browser evaluation may fail to load previews.
# Current Vercel global alias example:
# PREVIEW_PUBLIC_URL=https://your-designer-app.vercel.app
#
# Optional cap for prompt/response text written to the NDJSON observability file sink.
# This does not change model prompts, generated output, UI, or debug exports.
# It only limits how much text is retained in server-side log files.
# Default: production 2000 chars per field; development 0, meaning uncapped.
# Valid range: 0–10000000. Set 0 for no cap.
# Lower values reduce log size and sensitive-text exposure. Higher values preserve more
# debugging context but can create large logs.
# LLM_LOG_MAX_BODY_CHARS=2000

# Optional completion-token ceiling for model calls.
# Default: empty, so OpenRouter/model defaults and internal context-window budgeting apply.
# Valid range: 1–2097152. Most deployments should leave this empty.
# Lower values can reduce cost and latency but may truncate designs or agent reasoning.
# Higher values permit longer completions when the selected model supports them.
# MAX_OUTPUT_TOKENS=

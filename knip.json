{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.tsx",
    "server/dev.ts",
    "server/app.ts",
    "meta-harness/runner.tsx",
    "scripts/snap.ts",
    "scripts/bump-patch-version.ts"
  ],
  "ignore": [
    "api/**",
    "scripts/bump-patch-version.ts",
    "**/.vendor/**",
    "**/dist/**"
  ],
  "ignoreDependencies": [
    "@fontsource-variable/fraunces",
    "@fontsource-variable/inter-tight",
    "@fontsource-variable/jetbrains-mono",
    "tailwindcss"
  ],
  "workspaces": {
    "packages/design-system": {
      "entry": [
        "vitest.setup.ts",
        "__tests__/**/*.test.ts",
        "components/ui/__tests__/**/*.test.{ts,tsx}",
        "lib/__tests__/**/*.test.ts"
      ],
      "project": [
        "**/*.{ts,tsx,js,mjs}"
      ]
    }
  }
}

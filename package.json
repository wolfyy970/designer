{
  "name": "auto-designer",
  "private": true,
  "version": "0.3.17",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx watch server/dev.ts",
    "dev:all": "concurrently -k -n api,vite -c blue,green \"pnpm dev:server\" \"pnpm exec wait-on http://127.0.0.1:3001/api/health && vite\"",
    "dev:kill": "bash scripts/kill-dev-servers.sh",
    "langfuse:up": "docker compose -f docker/langfuse/docker-compose.yml up -d",
    "langfuse:down": "docker compose -f docker/langfuse/docker-compose.yml down",
    "db:seed": "tsx scripts/seed-langfuse.ts",
    "langfuse:sync-prompts": "LANGFUSE_SEED_SYNC=1 tsx scripts/seed-langfuse.ts",
    "knip": "knip || exit 0",
    "meta-harness": "tsx --tsconfig meta-harness/tsconfig.json meta-harness/runner.tsx",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/orbitron": "^5.2.8",
    "@hono/node-server": "^1.19.9",
    "@inkjs/ui": "^2.0.0",
    "@langfuse/client": "^5.0.2",
    "@langfuse/otel": "^5.0.2",
    "@langfuse/tracing": "^5.0.2",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@sinclair/typebox": "^0.34.48",
    "@tanstack/react-query": "^5.90.20",
    "@xyflow/react": "^12.10.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "fflate": "^0.8.2",
    "hono": "^4.12.0",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "ink": "^6.8.0",
    "ink-gradient": "^4.0.0",
    "jsonrepair": "^3.13.3",
    "just-bash": "^2.14.0",
    "lucide-react": "^0.563.0",
    "minimatch": "^10.2.5",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.4.0",
    "react-router-dom": "^7.13.0",
    "streamdown": "^2.5.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "knip": "^5.88.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Prompt {
  key      String          @id
  versions PromptVersion[]
}

model PromptVersion {
  id        Int      @id @default(autoincrement())
  promptKey String
  prompt    Prompt   @relation(fields: [promptKey], references: [key])
  body      String
  version   Int
  createdAt DateTime @default(now())

  @@unique([promptKey, version])
}

model Skill {
  key         String         @id
  name        String
  description String
  nodeTypes   String
  order       Int            @default(0)
  versions    SkillVersion[]
}

model SkillVersion {
  id        Int      @id @default(autoincrement())
  skillKey  String
  skill     Skill    @relation(fields: [skillKey], references: [key])
  body      String
  /** JSON map of relative path → file text for multi-file Agent Skills packages */
  filesJson String?
  version   Int
  createdAt DateTime @default(now())

  @@unique([skillKey, version])
}
